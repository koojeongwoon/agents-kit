# Copy to .env and fill in values (.env is gitignored)
#
#   cp .env.example .env
#
# Used by `agents-kit apply` to resolve ${VAR} placeholders in mcp/mcp-servers.json
# into mcp-servers.local.json (also gitignored, symlinked to clients).

# llm-wiki MCP server entrypoint
LLM_WIKI_MCP_PATH=/absolute/path/to/llm-wiki/mcp/server.js

# Optional: only if your context7 setup requires an API key
# CONTEXT7_API_KEY=
