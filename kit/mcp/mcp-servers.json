{
  "mcpServers": {
    "llm-wiki": {
      "command": "node",
      "args": [
        "${LLM_WIKI_MCP_PATH}"
      ],
      "description": "개인 지식베이스 Q&A 저널 및 요약 토픽 RAG 조회 MCP"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "description": "최신 라이브러리 및 API 공식 문서 실시간 조회 MCP"
    }
  }
}
